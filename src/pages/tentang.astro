---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Tentang Kami" description="Profil LAZISWAF Universitas Darussalam Gontor" currentPath="/tentang">
  <!-- Page Header -->
  <section class="page-header">
    <h1 class="animate-fade-in-up">Tentang LAZISWAF</h1>
    <p>Mengenal lebih dekat lembaga amil zakat, infak, sedekah, dan wakaf UNIDA Gontor</p>
  </section>

  <!-- Sejarah -->
  <section class="section">
    <div class="container">
      <div class="grid-2" style="align-items: center; gap: 4rem;">
        <div class="scroll-reveal">
          <h2 class="section-title">Sejarah Berdiri</h2>
          <p class="section-subtitle" style="margin-top: 1.5rem; max-width: 100%;">
            LAZISWAF Universitas Darussalam Gontor didirikan pada tanggal <strong>10 September 2010</strong> 
            sebagai lembaga pengelola dana zakat, infak, sedekah, dan wakaf di lingkungan Pondok Modern 
            Darussalam Gontor dan Universitas Darussalam Gontor.
          </p>
          <p class="section-subtitle" style="max-width: 100%;">
            Pendiriannya dikukuhkan melalui <strong>Surat Keputusan Rektor tanggal 8 April 2013</strong>, 
            yang menetapkan LAZISWAF sebagai lembaga resmi penghimpunan dan penyaluran dana umat di 
            lingkungan kampus.
          </p>
          <p class="section-subtitle" style="max-width: 100%;">
            Sejak berdiri, LAZISWAF telah menjadi jembatan kebaikan yang menghubungkan para donatur 
            dengan masyarakat yang membutuhkan, dengan tetap menjunjung tinggi nilai-nilai amanah, 
            profesionalisme, dan transparansi.
          </p>
        </div>
        <div class="tentang-image-wrap scroll-reveal scroll-reveal-delay-1">
          <img src="/images/pelantikan-pengurus.jpg" alt="Pelantikan Pengurus LAZISWAF" class="tentang-image" />
          <div class="tentang-image-dec"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visi Misi -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center scroll-reveal">
        <h2 class="section-title">Visi & Misi</h2>
      </div>
      <div class="grid-2" style="margin-top: 3rem; gap: 3rem;">
        <div class="visi-card card scroll-reveal">
          <div class="visi-icon">🎯</div>
          <h3 class="visi-title">Visi</h3>
          <p>Menjadi lembaga pengelola dana ZISWAF yang terpercaya, profesional, dan memberikan kemaslahatan bagi umat di lingkungan Universitas Darussalam Gontor dan masyarakat luas.</p>
        </div>
        <div class="visi-card card scroll-reveal scroll-reveal-delay-1">
          <div class="visi-icon">🚀</div>
          <h3 class="visi-title">Misi</h3>
          <ul class="misi-list">
            <li>Menghimpun dan mengelola dana ZISWAF secara profesional dan amanah</li>
            <li>Menyalurkan dana tepat sasaran kepada yang berhak</li>
            <li>Mengedukasi masyarakat tentang pentingnya ZISWAF</li>
            <li>Mengembangkan program pemberdayaan berbasis wakaf produktif</li>
            <li>Menjalin sinergi dengan lembaga dan relawan untuk dampak yang lebih luas</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Profil Singkat -->
  <section class="section">
    <div class="container">
      <div class="text-center scroll-reveal">
        <h2 class="section-title">Profil Lembaga</h2>
      </div>
      <div class="profil-grid scroll-reveal" style="margin-top: 3rem;">
        <div class="profil-item">
          <span class="profil-label">Nama Resmi</span>
          <span class="profil-value">LAZISWAF Universitas Darussalam Gontor</span>
        </div>
        <div class="profil-item">
          <span class="profil-label">Didirikan</span>
          <span class="profil-value">10 September 2010</span>
        </div>
        <div class="profil-item">
          <span class="profil-label">SK Rektor</span>
          <span class="profil-value">8 April 2013</span>
        </div>
        <div class="profil-item">
          <span class="profil-label">Akun Instagram</span>
          <span class="profil-value">@laziswaf.unidagontor</span>
        </div>
        <div class="profil-item">
          <span class="profil-label">Akun Instagram (Putri)</span>
          <span class="profil-value">@laziswaf.unidaputri</span>
        </div>
        <div class="profil-item">
          <span class="profil-label">Lokasi</span>
          <span class="profil-value">Jl. Raya Siman, Ponorogo, Jawa Timur</span>
        </div>
        <div class="profil-item">
          <span class="profil-label">Postingan</span>
          <span class="profil-value">279+ postingan kegiatan</span>
        </div>
        <div class="profil-item">
          <span class="profil-label">Followers</span>
          <span class="profil-value">1.225+ Pengikut</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center scroll-reveal">
        <h2 class="section-title" style="margin-bottom: 1rem;">Bergabung dalam Kebaikan</h2>
        <p class="section-subtitle" style="margin: 0 auto 2rem;">
          Mari menjadi bagian dari program-program kebaikan LAZISWAF UNIDA Gontor.
        </p>
        <a href="/kontak" class="btn btn-primary">
          Hubungi Kami
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tentang-image-wrap {
    position: relative;
  }

  .tentang-image {
    width: 100%;
    border-radius: 20px;
    position: relative;
    z-index: 1;
    box-shadow: var(--shadow-xl);
  }

  .tentang-image-dec {
    position: absolute;
    top: -15px;
    right: -15px;
    width: 100%;
    height: 100%;
    border: 3px solid var(--green-200);
    border-radius: 20px;
    z-index: 0;
  }

  .visi-card {
    padding: 2.5rem;
  }

  .visi-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .visi-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--green-800);
    margin-bottom: 1rem;
  }

  .visi-card p {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: var(--text-sm);
  }

  .misi-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .misi-list li {
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .misi-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--green-500);
    font-weight: 700;
  }

  .profil-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .profil-item {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    transition: all 0.3s;
  }

  .profil-item:hover {
    border-color: var(--green-200);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .profil-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .profil-value {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .profil-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
