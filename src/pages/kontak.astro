---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontak" description="Hubungi LAZISWAF Universitas Darussalam Gontor" currentPath="/kontak">
  <section class="page-header">
    <h1 class="animate-fade-in-up">Hubungi Kami</h1>
    <p>Silakan hubungi LAZISWAF UNIDA Gontor untuk informasi donasi dan program</p>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2" style="gap: 4rem;">
        <!-- Info Kontak -->
        <div>
          <div class="scroll-reveal">
            <h2 class="section-title">Informasi Kontak</h2>
            <p class="section-subtitle" style="margin-top: 1.5rem; max-width: 100%;">
              Hubungi kami untuk konsultasi, informasi program, atau penyaluran donasi ZISWAF.
              Tim LAZISWAF siap melayani Anda.
            </p>
          </div>

          <div class="kontak-items" style="margin-top: 2rem;">
            <div class="kontak-item card scroll-reveal">
              <div class="kontak-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <h3>Alamat</h3>
                <p>Kampus UNIDA Gontor<br/>Jl. Raya Siman, Demangan<br/>Siman, Ponorogo, Jawa Timur 63471</p>
              </div>
            </div>

            <div class="kontak-item card scroll-reveal scroll-reveal-delay-1">
              <div class="kontak-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <div>
                <h3>Telepon / WhatsApp</h3>
                <p><a href="tel:+6285159667366">0851-5966-7366</a></p>
              </div>
            </div>

            <div class="kontak-item card scroll-reveal scroll-reveal-delay-2">
              <div class="kontak-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <h3>Email</h3>
                <p><a href="mailto:laziswaf@unida.gontor.ac.id">laziswaf@unida.gontor.ac.id</a></p>
              </div>
            </div>

            <div class="kontak-item card scroll-reveal scroll-reveal-delay-3">
              <div class="kontak-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </div>
              <div>
                <h3>Instagram</h3>
                <p><a href="https://www.instagram.com/laziswaf.unidagontor/" target="_blank" rel="noopener noreferrer">@laziswaf.unidagontor</a></p>
                <p><a href="https://www.instagram.com/laziswaf.unidaputri/" target="_blank" rel="noopener noreferrer">@laziswaf.unidaputri</a></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Rekening & Donasi -->
        <div>
          <div class="scroll-reveal">
            <h2 class="section-title">Rekening Donasi</h2>
            <p class="section-subtitle" style="margin-top: 1.5rem; max-width: 100%;">
              Salurkan donasi terbaik Anda melalui rekening resmi LAZISWAF UNIDA Gontor.
            </p>
          </div>

          <div class="donasi-card card scroll-reveal scroll-reveal-delay-1" style="margin-top: 2rem; padding: 2.5rem;">
            <div class="donasi-bank-label">Bank Syariah Indonesia</div>
            <div class="donasi-number">1010 63 2297</div>
            <div class="donasi-name">a.n. LAZISWAF UNIDA Gontor</div>
            <div class="donasi-divider"></div>
            <div class="donasi-info">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
              </svg>
              <span>Konfirmasi transfer: 0851-5966-7366 (WhatsApp)</span>
            </div>
          </div>

          <!-- Lokasi -->
          <div class="scroll-reveal" style="margin-top: 3rem;">
            <h2 class="section-title">Lokasi Kami</h2>
          </div>
          <div class="map-container scroll-reveal scroll-reveal-delay-1" style="margin-top: 1.5rem;">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3955.1436959149857!2d111.4857!3d-7.9534!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e79a0e2f0b2c1e1%3A0x9e8c5f3b5e5b5f0!2sUniversitas%20Darussalam%20Gontor!5e0!3m2!1sid!2sid!4v1"
              width="100%"
              height="300"
              style="border:0; border-radius: 16px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Lokasi UNIDA Gontor"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .kontak-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .kontak-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    cursor: default;
  }

  .kontak-item:hover {
    transform: translateX(4px);
    border-color: var(--green-200);
  }

  .kontak-icon {
    width: 48px;
    height: 48px;
    background: var(--green-50);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--green-600);
  }

  .kontak-item h3 {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--green-800);
    margin-bottom: 0.25rem;
  }

  .kontak-item p {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }

  .kontak-item a {
    color: var(--green-600);
  }

  .kontak-item a:hover {
    color: var(--green-700);
    text-decoration: underline;
  }

  .donasi-card {
    background: linear-gradient(135deg, var(--green-900), var(--green-800));
    color: white;
    position: relative;
    overflow: hidden;
  }

  .donasi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .donasi-card:hover {
    transform: none;
  }

  .donasi-bank-label {
    position: relative;
    font-size: var(--text-sm);
    color: var(--green-300);
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .donasi-number {
    position: relative;
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 800;
    letter-spacing: 3px;
    color: white;
    margin-bottom: 0.5rem;
  }

  .donasi-name {
    position: relative;
    font-size: var(--text-base);
    color: var(--green-200);
  }

  .donasi-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
    margin: 1.5rem 0;
    position: relative;
  }

  .donasi-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    color: var(--green-300);
    position: relative;
  }

  .donasi-info svg {
    flex-shrink: 0;
  }

  .map-container {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 768px) {
    .donasi-number {
      font-size: var(--text-3xl);
    }
  }
</style>
