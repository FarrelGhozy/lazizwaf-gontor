---
// KegiatanCard.astro — Card berita/kegiatan
export interface Props {
  image: string;
  alt: string;
  title: string;
  date: string;
  description: string;
}

const { image, alt, title, date, description } = Astro.props;
---

<article class="kegiatan-card card scroll-reveal">
  <div class="kegiatan-image">
    <img src={image} alt={alt} loading="lazy" />
    <div class="kegiatan-date">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      {date}
    </div>
  </div>
  <div class="kegiatan-body">
    <h3 class="kegiatan-title">{title}</h3>
    <p class="kegiatan-desc">{description}</p>
  </div>
</article>

<style>
  .kegiatan-card {
    overflow: hidden;
  }

  .kegiatan-image {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .kegiatan-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .kegiatan-card:hover .kegiatan-image img {
    transform: scale(1.08);
  }

  .kegiatan-date {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    background: rgba(13, 40, 24, 0.85);
    backdrop-filter: blur(8px);
    color: white;
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: 8px;
  }

  .kegiatan-body {
    padding: 1.5rem;
  }

  .kegiatan-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--green-800);
    margin-bottom: 0.6rem;
    line-height: 1.4;
  }

  .kegiatan-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
