---
// Hero.astro — Hero section untuk Beranda
export interface Props {
  title: string;
  subtitle: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
}

const { title, subtitle, primaryCta, secondaryCta } = Astro.props;
---

<section class="hero">
  <div class="hero-bg-pattern"></div>
  <div class="container hero-content">
    <div class="hero-text">
      <div class="hero-badge animate-fade-in">
        <span class="badge-dot"></span>
        Lembaga Zakat, Infak, Sedekah & Wakaf
      </div>
      <h1 class="hero-title animate-fade-in-up">{title}</h1>
      <p class="hero-subtitle animate-fade-in-up">{subtitle}</p>
      <div class="hero-actions">
        {primaryCta && (
          <a href={primaryCta.href} class="btn btn-primary btn-lg">{primaryCta.text}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-white">{secondaryCta.text}</a>
        )}
      </div>
    </div>
    <div class="hero-visual animate-fade-in">
      <div class="hero-card-stack">
        <div class="hero-card card-1">
          <div class="card-icon">🤝</div>
          <div class="card-label">Zakat</div>
        </div>
        <div class="hero-card card-2">
          <div class="card-icon">💝</div>
          <div class="card-label">Sedekah</div>
        </div>
        <div class="hero-card card-3">
          <div class="card-icon">📖</div>
          <div class="card-label">Wakaf</div>
        </div>
      </div>
    </div>
  </div>
  <div class="hero-wave">
    <svg viewBox="0 0 1440 100" fill="none" preserveAspectRatio="none">
      <path d="M0 50C240 100 480 0 720 50C960 100 1200 0 1440 50V100H0V50Z" fill="#f5f0e8"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, var(--green-900) 0%, var(--green-800) 50%, #0a5e30 100%);
    overflow: hidden;
    padding: 6rem 0 0;
  }

  .hero-bg-pattern {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(16, 185, 129, 0.1) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(212, 168, 67, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(5, 150, 105, 0.06) 0%, transparent 50%);
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    padding: 2rem 0;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    color: var(--green-200);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(10px);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--green-400);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: white;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero-title::after {
    content: '';
    display: block;
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, var(--green-400), var(--gold-500));
    border-radius: 2px;
    margin-top: 1rem;
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Hero Visual - Card Stack */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-card-stack {
    position: relative;
    width: 280px;
    height: 320px;
  }

  .hero-card {
    position: absolute;
    width: 200px;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-icon {
    font-size: 2.5rem;
  }

  .card-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--green-800);
  }

  .card-1 {
    top: 0;
    right: 0;
    transform: rotate(6deg);
    animation: float 4s ease-in-out infinite;
  }

  .card-2 {
    top: 80px;
    left: 0;
    transform: rotate(-3deg);
    animation: float 4s ease-in-out infinite 1s;
  }

  .card-3 {
    bottom: 0;
    right: 20px;
    transform: rotate(4deg);
    animation: float 4s ease-in-out infinite 2s;
  }

  @keyframes float {
    0%, 100% { transform: rotate(var(--tw-rotate, 0deg)) translateY(0px); }
    50% { transform: rotate(var(--tw-rotate, 0deg)) translateY(-10px); }
  }

  /* Wave */
  .hero-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .hero-wave svg {
    width: 100%;
    height: 60px;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 0 0;
      min-height: auto;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
      padding-top: 2rem;
    }

    .hero-title::after {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-visual {
      display: none;
    }

    .hero-wave svg {
      height: 40px;
    }
  }
</style>
